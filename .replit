modules = ["nodejs-20"]

[agent]
expertMode = true

[nix]
packages = ["libuuid"]

[[ports]]
localPort = 3000
externalPort = 3000

[deployment]
run = ["node", "index.js"]
deploymentTarget = "vm"
build = ["npm", "install"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Discord Bot"

[[workflows.workflow]]
name = "Discord Bot"
author = "agent"

# Console / Runボタンでは起動させない（案内だけ表示）
[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'This bot is Deployment-only. Use Publish/Deployment.'"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.production]
PORT = "3000"
DEPLOYMENT = "true"
STARTUP_GUARD = "your-random-long-string"
