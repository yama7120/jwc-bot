<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
  <title>JWC | Japan War Clans</title>
	<meta name="description" content="JWC is the one of the oldest-running competitions in Clash of Clans" />
	<meta name="keywords" content="japan war clans, clash of clans" />
	<meta name="author" content="yama | GaihaziBomber 2 | Clash of Clans" />
	<meta name="theme-color" content="#ffffff">
	<!-- Normalize -->
	<link rel="stylesheet" type="text/css" href="css/normalize.css">
	<!-- Bootstrap -->
	<link rel="stylesheet" type="text/css" href="css/bootstrap.css">
	<!-- Owl -->
	<link rel="stylesheet" type="text/css" href="css/owl.css">
	<!-- Animate.css -->
	<link rel="stylesheet" type="text/css" href="css/animate.css">
	<!-- Main style -->
	<link rel="stylesheet" type="text/css" href="css/main.css">
</head>

<body>
	<div class="preloader">
		<img src="img/loader.gif" alt="Preloader image">
	</div>
	<nav class="navbar">
		<div class="container">
			<!-- Brand and toggle get grouped for better mobile display -->
			<div class="navbar-header">
				<button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#bs-example-navbar-collapse-1">
					<span class="sr-only">Toggle navigation</span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
				</button>
			</div>
			<!-- Collect the nav links, forms, and other content for toggling -->
			<div class="collapse navbar-collapse">
				<ul class="nav navbar-nav navbar-right main-nav">
					<li><a href="#top">TOP</a></li>
					<li><a href="/j1#j1">J1</a></li>
					<li><a href="/j2#j2">J2</a></li>
					<li><a href="/swiss#swiss">SWISS</a></li>
					<li><a href="/mix#mix">MIX</a></li>
				</ul>
			</div>
		</div>
	</nav>
	<header id="top">
		<div class="container">
			<div class="table">
				<div class="header-text">
					<div class="row">
						<div class="col-md-12 text-center">
							<h5 class="light white">Japan War Clans</h5>
							<h1 class="white">JWC</h1>
						</div>
					</div>
				</div>
			</div>
		</div>
	</header>
	<section>
		<div class="cut cut-top"></div>
	</section>
  <%_ let dataWarStatsCurrentParsed = JSON.parse(dataWarStatsCurrent); _%>
	<section id="current" class="section section-padded white-bg">
  <current>
    <div class="container">
      <div class="row text-center">
        <div class="col-md-12">
          <a href="<%- config.urlImage.season14 %>">
            <img src="img/jwc/header.jpeg" class="large">
          </a>
          <!-- caption -->
          <div class="row">
            <span data-css-icon="down">
              <div class="col-xs-12"><h6 class="italic"><span class="preparation"></span>preparation</h6></div>
              <div class="col-xs-12"><h6 class="italic"><span class="inWar"></span>now in war</h6></div>
              <div class="col-xs-12"><h6 class="italic"><span class="warEnded"></span>war has ended</h6></div>
            </span>
          </div>
          <!-- link -->
          <div class="row">
            <div class="col-xs-12">
					     <h2 class="j1">J1</h2>
              <%_ var league = "j1"; _%>
              <%_ var weekNowStr = `w${config.weekNow[league]}`; _%>
              <h5 class="padded">Week <%- config.weekNow[league] %></h5>
              <%_ for (var i = 0; i < Object.keys(dataWarStatsCurrentParsed[league]).length; i++) { _%>
                <%_ let matchStr = `m${i+1}`; _%>
                <%_ var thisDataWarStats = dataWarStatsCurrentParsed[league][matchStr]; _%>
                <%_ var deal = dataWarStatsCurrentParsed[league][matchStr].deal; _%>
                <h6 class="link">
                  <span class="<%- thisDataWarStats.state %>"></span>
                  <%- `${i+1}. ` %>
                    <a href="#<%- `${league}-${matchStr}` %>"><%- `<b>${thisDataWarStats.teamName[0].replace(/\\/g, "")}</b>  vs  <b>${thisDataWarStats.teamName[1].replace(/\\/g, "")}</b>` %></a>
                </h6>
                <%_ if (thisDataWarStats.state == "beforeTheWar") { _%> <!-- beforeTheWar -->
                  <%_ if (deal == "") { _%>
                    <h6><i>not scheduled yet</i></h6>
                  <%_ } else { _%>
                    <h6><%- `${deal.date}` %> <%- `${deal.time}` %></h6>
                    <h6><%- `${deal.prep_time} / ${deal.battle_time}` %></h6>
                  <%_ }; _%>
                <%_ } else if (thisDataWarStats.state == "preparation") { _%> <!-- preparation -->
                  <h6 class="orange">
                    <span class="hour-<%- league %>-<%- matchStr %>"></span>:<span class="min-<%- league %>-<%- matchStr %>"></span>:<span class="sec-<%- league %>-<%- matchStr %>"></span>
                  </h6>
                <%_ } else { _%> <!-- inWar / warEnded -->
                  <%_ var triByAt1 = `${thisDataWarStats.clan.allAttackTypes.nTriple.total}/${thisDataWarStats.clan.allAttackTypes.nAt.total}` _%>
                  <%_ var triByAt2 = `${thisDataWarStats.opponent.allAttackTypes.nTriple.total}/${thisDataWarStats.opponent.allAttackTypes.nAt.total}` _%>
                  <%_ var hitrate1 = Math.round(thisDataWarStats.clan.allAttackTypes.hitrate.total * 10) / 10 _%>
                  <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.allAttackTypes.hitrate.total * 10) / 10 _%>
                  <h6><%- `${triByAt1} (${hitrate1}%)` %> - <%- `${triByAt2} (${hitrate2}%)` %></h6>
                  <%_ if (thisDataWarStats.state == "inWar") { _%> <!-- inWar -->
                    <h6 class="red">
                      <span class="hour-<%- league %>-<%- matchStr %>"></span>:<span class="min-<%- league %>-<%- matchStr %>"></span>:<span class="sec-<%- league %>-<%- matchStr %>"></span>
                    </h6>
                  <%_ }; _%>
                <%_ }; _%>
              <%_ }; _%>
            </div>
            <div class="col-xs-12">
