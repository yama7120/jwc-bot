          var min = Math.floor(differ / 1000 / 60) % 60;
          var hour = Math.floor(differ / 1000 / 60 / 60);
          elmHour.textContent = String(hour);
          elmMin.textContent = String(min).padStart(2, "0");
          elmSec.textContent = String(sec).padStart(2, "0");
        };
      });
