                  <%_ var triByAt2 = `${thisDataWarStats.opponent.allAttackTypes.nTriple.total}/${thisDataWarStats.opponent.allAttackTypes.nAt.total}` _%>
                  <%_ var hitrate1 = Math.round(thisDataWarStats.clan.allAttackTypes.hitrate.total * 10) / 10 _%>
