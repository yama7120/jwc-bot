  <script>
    let dataWarStatsCurrent = JSON.parse('<%- dataWarStatsCurrent %>');
    const rewriteTime = () => {
      var league = "j1";
      Object.keys(dataWarStatsCurrent[league]).map((match, index) => {
        var state = dataWarStatsCurrent[league][match].state;
        var elmHour = document.querySelector(`.hour-${league}-${match}`);
        var elmMin = document.querySelector(`.min-${league}-${match}`);
        var elmSec = document.querySelector(`.sec-${league}-${match}`);
        const now = new Date();
        var start = new Date();
        if (state == "preparation") {
          start = new Date(dataWarStatsCurrent[league][match].startTime);
        }
        else if (state == "inWar") {
          start = new Date(dataWarStatsCurrent[league][match].endTime);
        };
        if (state == "preparation" || state == "inWar") {
          var differ = start.getTime() - now.getTime();
          var sec = Math.floor(differ / 1000) % 60;
          var min = Math.floor(differ / 1000 / 60) % 60;
          var hour = Math.floor(differ / 1000 / 60 / 60);
          elmHour.textContent = String(hour);
          elmMin.textContent = String(min).padStart(2, "0");
          elmSec.textContent = String(sec).padStart(2, "0");
        };
