        var start = new Date();
        if (state == "preparation") {
          start = new Date(dataWarStatsCurrent[league][match].startTime);
        }
        else if (state == "inWar") {
          start = new Date(dataWarStatsCurrent[league][match].endTime);
        };
        if (state == "preparation" || state == "inWar") {
          var differ = start.getTime() - now.getTime();
          var sec = Math.floor(differ / 1000) % 60;
          var min = Math.floor(differ / 1000 / 60) % 60;
          var hour = Math.floor(differ / 1000 / 60 / 60);
