                    </h6>
                  <%_ }; _%>
                <%_ }; _%>
              <%_ }; _%>
            </div>
            <div class="col-xs-12">
					     <h2 class="swiss">SWISS</h2>
              <%_ var league = "swiss"; _%>
              <%_ var weekNowStr = `w${config.weekNow[league]}`; _%>
              <h5 class="padded">Week <%- config.weekNow[league] %></h5>
              <%_ for (var i = 0; i < Object.keys(dataWarStatsCurrentParsed[league]).length; i++) { _%>
                <%_ let matchStr = `m${i+1}`; _%>
                <%_ var thisDataWarStats = dataWarStatsCurrentParsed[league][matchStr]; _%>
                <%_ var deal = dataWarStatsCurrentParsed[league][matchStr].deal; _%>
                <h6 class="link">
                  <span class="<%- thisDataWarStats.state %>"></span>
                  <%- `${i+1}. ` %>
                    <a href="#<%- `${league}-${matchStr}` %>"><%- `<b>${thisDataWarStats.teamName[0].replace(/\\/g, "")}</b>  vs  <b>${thisDataWarStats.teamName[1].replace(/\\/g, "")}</b>` %></a>
                </h6>
                <%_ if (thisDataWarStats.state == "beforeTheWar") { _%> <!-- beforeTheWar -->
                  <%_ if (deal == "") { _%>
                    <h6><i>not scheduled yet</i></h6>
                  <%_ } else { _%>
                    <h6><%- `${deal.date}` %> <%- `${deal.time}` %></h6>
                    <h6><%- `${deal.prep_time} / ${deal.battle_time}` %></h6>
                  <%_ }; _%>
                <%_ } else if (thisDataWarStats.state == "preparation") { _%> <!-- preparation -->
                  <h6 class="orange">
                    <span class="hour-<%- league %>-<%- matchStr %>"></span>:<span class="min-<%- league %>-<%- matchStr %>"></span>:<span class="sec-<%- league %>-<%- matchStr %>"></span>
                  </h6>
                <%_ } else { _%> <!-- inWar / warEnded -->
                  <%_ var triByAt1 = `${thisDataWarStats.clan.allAttackTypes.nTriple.total}/${thisDataWarStats.clan.allAttackTypes.nAt.total}` _%>
                  <%_ var triByAt2 = `${thisDataWarStats.opponent.allAttackTypes.nTriple.total}/${thisDataWarStats.opponent.allAttackTypes.nAt.total}` _%>
                  <%_ var hitrate1 = Math.round(thisDataWarStats.clan.allAttackTypes.hitrate.total * 10) / 10 _%>
                  <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.allAttackTypes.hitrate.total * 10) / 10 _%>
                  <h6><%- `${triByAt1} (${hitrate1}%)` %> - <%- `${triByAt2} (${hitrate2}%)` %></h6>
                  <%_ if (thisDataWarStats.state == "inWar") { _%> <!-- inWar -->
                    <h6 class="red">
                      <span class="hour-<%- league %>-<%- matchStr %>"></span>:<span class="min-<%- league %>-<%- matchStr %>"></span>:<span class="sec-<%- league %>-<%- matchStr %>"></span>
                    </h6>
                  <%_ }; _%>
                <%_ }; _%>
              <%_ }; _%>
            </div>
            <div class="col-xs-12">
					     <h2 class="mix">MIX</h2>
              <%_ var league = "mix"; _%>
              <%_ var weekNowStr = `w${config.weekNow[league]}`; _%>
              <h5 class="padded">Week <%- config.weekNow[league] %></h5>
              <%_ for (var i = 0; i < Object.keys(dataWarStatsCurrentParsed[league]).length; i++) { _%>
                <%_ let matchStr = `m${i+1}`; _%>
                <%_ var thisDataWarStats = dataWarStatsCurrentParsed[league][matchStr]; _%>
                <%_ var deal = dataWarStatsCurrentParsed[league][matchStr].deal; _%>
                <h6 class="link">
                  <span class="<%- thisDataWarStats.state %>"></span>
                  <%- `${i+1}. ` %>
                    <a href="#<%- `${league}-${matchStr}` %>"><%- `<b>${thisDataWarStats.teamName[0].replace(/\\/g, "")}</b>  vs  <b>${thisDataWarStats.teamName[1].replace(/\\/g, "")}</b>` %></a>
                </h6>
                <%_ if (thisDataWarStats.state == "beforeTheWar") { _%> <!-- beforeTheWar -->
                  <%_ if (deal == "") { _%>
                    <h6><i>not scheduled yet</i></h6>
                  <%_ } else { _%>
                    <h6><%- `${deal.date}` %> <%- `${deal.time}` %></h6>
                    <h6><%- `${deal.prep_time} / ${deal.battle_time}` %></h6>
                  <%_ }; _%>
                <%_ } else if (thisDataWarStats.state == "preparation") { _%> <!-- preparation -->
                  <h6 class="orange">
                    <span class="hour-<%- league %>-<%- matchStr %>"></span>:<span class="min-<%- league %>-<%- matchStr %>"></span>:<span class="sec-<%- league %>-<%- matchStr %>"></span>
                  </h6>
                <%_ } else { _%> <!-- inWar / warEnded -->
                  <%_ var triByAt1 = `${thisDataWarStats.clan.allAttackTypes.nTriple.total}/${thisDataWarStats.clan.allAttackTypes.nAt.total}` _%>
                  <%_ var triByAt2 = `${thisDataWarStats.opponent.allAttackTypes.nTriple.total}/${thisDataWarStats.opponent.allAttackTypes.nAt.total}` _%>
                  <%_ var hitrate1 = Math.round(thisDataWarStats.clan.allAttackTypes.hitrate.total * 10) / 10 _%>
                  <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.allAttackTypes.hitrate.total * 10) / 10 _%>
                  <h6><%- `${triByAt1} (${hitrate1}%)` %> - <%- `${triByAt2} (${hitrate2}%)` %></h6>
                  <%_ if (thisDataWarStats.state == "inWar") { _%> <!-- inWar -->
                    <h6 class="red">
                      <span class="hour-<%- league %>-<%- matchStr %>"></span>:<span class="min-<%- league %>-<%- matchStr %>"></span>:<span class="sec-<%- league %>-<%- matchStr %>"></span>
                    </h6>
                  <%_ }; _%>
