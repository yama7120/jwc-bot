          </div>
          <!-- ***** J1 ***** -->
					<h2 class="j1">J1</h2>
          <%_ var league = "j1"; _%>
          <%_ var weekNowStr = `w${config.weekNow[league]}`; _%>
          <h5 class="padded">Week <%- config.weekNow[league] %></h5>
          <%_ for (var i = 0; i < Object.keys(dataWarStatsCurrentParsed[league]).length; i++) { _%>
            <%_ let matchStr = `m${i+1}`; _%>
            <%_ var thisDataWarStats = dataWarStatsCurrentParsed[league][matchStr]; _%>
            <%_ if (thisDataWarStats.state == "inWar") { _%>
            <details open>
            <%_ } else { _%>
            <details>
            <%_ }; _%>
              <summary id=<%- `${league}-${matchStr}` %>>
                <span data-css-icon="down">
                  <h6><span class="<%- thisDataWarStats.state %>"></span><%- `<b>${i+1}. ${thisDataWarStats.teamName[0].replace(/\\/g, "")}</b>  vs  <b>${thisDataWarStats.teamName[1].replace(/\\/g, "")}</b>` %></h6><i></i>
                </span>
              </summary>
              <%_ if (thisDataWarStats.nameMatch != "-") { _%>
                <div class="row">
                  <div class="col-md-12">
                    <h6><i><%- `${thisDataWarStats.nameMatch}` %></i></h6>
                  </div>
                </div>
              <%_ }; _%>
              <!-- beforeTheWar -->
              <%_ if (thisDataWarStats.state == "beforeTheWar") { _%>
                <div class="row">
                  <div class="col-md-12">
                    <%_ var deal = dataWarStatsCurrentParsed[league][matchStr].deal; _%>
                    <%_ if (deal == "") { _%>
                      <h6><i>not scheduled yet</i></h6>
                    <%_ } else { _%>
                      <h6><%- `${deal.date}` %></h6>
                      <h6><%- `${deal.time}` %></h6>
                      <h6><%- `${deal.prep_time} / ${deal.battle_time}` %></h6>
                    <%_ }; _%>
                  </div>
                </div>
              <!-- preparation -->
              <%_ } else if (thisDataWarStats.state == "preparation") { _%>
                <div class="row">
                  <div class="col-md-12">
                    <%_ var deal = dataWarStatsCurrentParsed[league][matchStr].deal; _%>
                    <%_ if (deal == "") { _%>
                      <h6><i>not scheduled yet</i></h6>
                    <%_ } else { _%>
                      <h6><%- `${deal.date}` %></h6>
                      <h6><%- `${deal.time}` %></h6>
                      <h6><%- `${deal.prep_time} / ${deal.battle_time}` %></h6>
                    <%_ }; _%>
                  </div>
                </div>
              <!-- inWar or warEnded -->
              <%_ } else { _%>
                <div class="row">
                  <div class="col-sm-12">
                    <div class="row">
                      <div class="col-sm-10 col-sm-offset-1">
                        <%_ var idChartTriples = `chartTriples-${league}-${matchStr}`; _%>
                        <canvas id="<%- idChartTriples %>"></canvas>
                      </div>
                    </div>
                    <div class="row">
                      <h5 class="padded">Stats</h5>
                      <div class="col-xs-5"><h6 class="right bold"><%- thisDataWarStats.clan.stars %></h6></div>
                      <div class="col-xs-2"><h6>Stars</h6></div>
                      <div class="col-xs-5"><h6 class="left bold"><%- thisDataWarStats.opponent.stars %></h6></div>
                      <div class="col-xs-5"><h6 class="right bold"><%- thisDataWarStats.clan.destruction %>%</h6></div>
                      <div class="col-xs-2"><h6>Dest.</h6></div>
                      <div class="col-xs-5"><h6 class="left bold"><%- thisDataWarStats.opponent.destruction %>%</h6></div>
                      <!-- hitrate -->
                      <%_ var triByAt1 = `${thisDataWarStats.clan.allAttackTypes.nTriple.total}/${thisDataWarStats.clan.allAttackTypes.nAt.total}` _%>
                      <%_ var triByAt2 = `${thisDataWarStats.opponent.allAttackTypes.nTriple.total}/${thisDataWarStats.opponent.allAttackTypes.nAt.total}` _%>
                      <%_ var hitrate1 = Math.round(thisDataWarStats.clan.allAttackTypes.hitrate.total * 10) / 10 _%>
                      <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.allAttackTypes.hitrate.total * 10) / 10 _%>
                      <div class="col-xs-5"><h6 class="right bold"><%- `${triByAt1} (${hitrate1}%)` %></h6></div>
                      <div class="col-xs-2"><h6>Hitrate</h6></div>
                      <div class="col-xs-5"><h6 class="left bold"><%- `${triByAt2} (${hitrate2}%)` %></h6></div>
                      <!-- Fresh -->
                      <%_ if (league != "swiss") { _%>
                        <%_ var triByAt1 = `${thisDataWarStats.clan.fresh.nTriple.total}/${thisDataWarStats.clan.fresh.nAt.total}` _%>
                        <%_ var triByAt2 = `${thisDataWarStats.opponent.fresh.nTriple.total}/${thisDataWarStats.opponent.fresh.nAt.total}` _%>
                        <%_ var hitrate1 = Math.round(thisDataWarStats.clan.fresh.hitrate.total * 10) / 10 _%>
                        <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.fresh.hitrate.total * 10) / 10 _%>
                        <div class="col-xs-5"><h6 class="right bold"><%- `${triByAt1} (${hitrate1}%)` %></h6></div>
                        <div class="col-xs-2"><h6>(Fresh)</h6></div>
                        <div class="col-xs-5"><h6 class="left bold"><%- `${triByAt2} (${hitrate2}%)` %></h6></div>
                      <%_ }; _%>
                      <!-- Cleanup -->
                      <%_ if (thisDataWarStats.clan.cleanup.nTriple.total + thisDataWarStats.clan.cleanup.nAt.total > 0) { _%>
                        <%_ var triByAt1 = `${thisDataWarStats.clan.cleanup.nTriple.total}/${thisDataWarStats.clan.cleanup.nAt.total}` _%>
                        <%_ var triByAt2 = `${thisDataWarStats.opponent.cleanup.nTriple.total}/${thisDataWarStats.opponent.cleanup.nAt.total}` _%>
                        <%_ var hitrate1 = Math.round(thisDataWarStats.clan.cleanup.hitrate.total * 10) / 10 _%>
                        <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.cleanup.hitrate.total * 10) / 10 _%>
                        <div class="col-xs-5"><h6 class="right bold"><%- `${triByAt1} (${hitrate1}%)` %></h6></div>
                        <div class="col-xs-2"><h6>(Cleanup)</h6></div>
                        <div class="col-xs-5"><h6 class="left bold"><%- `${triByAt2} (${hitrate2}%)` %></h6></div>
                      <%_ }; _%>
                      <!-- Overkill -->
                      <%_ if (thisDataWarStats.clan.overkill.nTriple.total + thisDataWarStats.clan.overkill.nAt.total > 0) { _%>
                        <%_ var triByAt1 = `${thisDataWarStats.clan.overkill.nTriple.total}/${thisDataWarStats.clan.overkill.nAt.total}` _%>
                        <%_ var triByAt2 = `${thisDataWarStats.opponent.overkill.nTriple.total}/${thisDataWarStats.opponent.overkill.nAt.total}` _%>
                        <%_ var hitrate1 = Math.round(thisDataWarStats.clan.overkill.hitrate.total * 10) / 10 _%>
                        <%_ var hitrate2 = Math.round(thisDataWarStats.opponent.overkill.hitrate.total * 10) / 10 _%>
                        <div class="col-xs-5"><h6 class="right bold"><%- `${triByAt1} (${hitrate1}%)` %></h6></div>
                        <div class="col-xs-2"><h6>(Overkill)</h6></div>
                        <div class="col-xs-5"><h6 class="left bold"><%- `${triByAt2} (${hitrate2}%)` %></h6></div>
                      <%_ }; _%>
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-8 col-md-offset-2">
                    <h5 class="padded">Remining Attacks</h5>
                    <%_ var attacks = dataWarStatsCurrentParsed[league][matchStr].attacks; _%>
                    <%_ var remainingAttacks = ["", ""]; _%>
                    <%_ attacks.map((attack) => { _%>
                      <%_ if (attack.attackType == "remaining") { _%>
                        <%_ if (attack.action == "attack") { _%>
                          <%_ remainingAttacks[0] += `${attack.name} <img src=img/th/th${attack.townHallLevel}.png class=thLeft><br>`;_%>
                        <%_ } else { _%>
                          <%_ remainingAttacks[1] += `<img src=img/th/th${attack.townHallLevel}.png class=thRight> ${attack.name}<br>`;_%>
                        <%_ }; _%>
                      <%_ }; _%>
                    <%_ }); _%>
                    <%_ if (remainingAttacks[0].length == 0) { _%>
                      <%_ remainingAttacks[0] = `<h6 class="italic">no attacks</h6>`; _%>
                    <%_ }; _%>
                    <%_ if (remainingAttacks[1].length == 0) { _%>
                      <%_ remainingAttacks[1] = `<h6 class="italic">no attacks</h6>`; _%>
                    <%_ }; _%>
                    <div class="row">
                      <div class="col-xs-6">
                        <h6 class="right"><%- remainingAttacks[0] %></h6>
                      </div>
                      <div class="col-xs-6">
                        <h6 class="left"><%- remainingAttacks[1] %></h6>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Attacks -->
                <div class="row">
