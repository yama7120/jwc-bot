<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
  <title>JWC | Japan War Clans</title>
	<meta name="description" content="JWC is the one of the oldest-running competitions in Clash of Clans" />
	<meta name="keywords" content="japan war clans, clash of clans, local league" />
	<meta name="author" content="yama | GaihaziBomber 2 | Clash of Clans" />
	<meta name="theme-color" content="#ffffff">
	<!-- Normalize -->
	<link rel="stylesheet" type="text/css" href="css/normalize.css">
	<!-- Bootstrap -->
	<link rel="stylesheet" type="text/css" href="css/bootstrap.css">
	<!-- Owl -->
	<link rel="stylesheet" type="text/css" href="css/owl.css">
	<!-- Animate.css -->
	<link rel="stylesheet" type="text/css" href="css/animate.css">
	<!-- Main style -->
	<link rel="stylesheet" type="text/css" href="css/main.css">
  <!-- dataTables -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.css" />
</head>

<body>
	<div class="preloader">
		<img src="img/loader.gif" alt="Preloader image">
	</div>
	<nav class="navbar">
		<div class="container">
			<!-- Brand and toggle get grouped for better mobile display -->
			<div class="navbar-header">
				<button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#bs-example-navbar-collapse-1">
					<span class="sr-only">Toggle navigation</span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
					<span class="icon-bar"></span>
				</button>
			</div>
			<!-- Collect the nav links, forms, and other content for toggling -->
			<div class="collapse navbar-collapse">
				<ul class="nav navbar-nav navbar-right main-nav">
					<li><a href="/#top">TOP</a></li>
					<li><a href="/j1#j1">J1</a></li>
					<li><a href="/j2#j2">J2</a></li>
					<li><a href="/swiss#swiss">SWISS</a></li>
					<li><a href="/mix#mix">MIX</a></li>
				</ul>
			</div>
		</div>
	</nav>
	<header id="top">
		<div class="container">
			<div class="table">
				<div class="header-text">
					<div class="row">
						<div class="col-md-12 text-center">
							<h5 class="light white">Japan War Clans</h5>
							<h1 class="white">JWC</h1>
						</div>
					</div>
				</div>
			</div>
		</div>
	</header>
	<section>
		<div class="cut cut-top"></div>
	</section>
  <%_ let clanAbbrListParsed = JSON.parse(clanAbbrList); _%>
  <%_ let dataTeamsParsed = JSON.parse(dataTeams.replace(/\\\\/g, '')); _%>
  <!-- ##### ##### ##### ##### ##### ##### ##### MIX ##### ##### ##### ##### ##### ##### ##### -->
	<section id="mix" class="section section-padded white-bg">
		<div class="container">
      <div class="row text-center">
        <div class="col-md-12">
          <h2 class="mix">MIX</h2>
          <h4 class="padded">REGULAR SEASON</h4>
          <table id="standings-mix" class="stripe nowrap"></table>
          <h4 class="padded">PLAYOFFS</h4>
          <iframe src="https://challonge.com/ja/jwc_s14_mix/module" width="100%" height="600" frameborder="0" scrolling="auto" allowtransparency="true"></iframe>
        </div>
      </div>
      <div class="row text-center">
        <div class="col-md-12">
          <h4 class="padded">CLANS</h4>
          <%_ var league = "mix"; _%>
          <% for (var i = 0; i < clanAbbrListParsed[league].length; i++) { %>
          <%_ let clanAbbr = clanAbbrListParsed[league][i]; _%>
          <details>
            <summary>
              <span data-css-icon="down">
                <h6><b><%- `${i+1}. ${clanAbbr.replace('clan_', '').toUpperCase()}  |  ${dataTeamsParsed[clanAbbr].team_name}` %></h6></b><i></i>
              </span>
            </summary>
            <div class="row">
              <div class="col-md-12">
                <img src="<%- dataTeamsParsed[clanAbbr].logo_url %>" class="avatar">
                <div class="row">
                  <h5 class="padded">Summary</h5>
                  <div class="col-xs-6"><h6 class="right">Won</h6></div>
                  <div class="col-xs-6"><h6 class="left"><%- dataTeamsParsed[clanAbbr].summary.nWin %></h6></div>
                  <div class="col-xs-6"><h6 class="right">Lost</h6></div>
                  <div class="col-xs-6"><h6 class="left"><%- dataTeamsParsed[clanAbbr].summary.nLoss %></h6></div>
                  <div class="col-xs-6"><h6 class="right">Star Difference</h6></div>
                  <div class="col-xs-6"><h6 class="left"><%- dataTeamsParsed[clanAbbr].summary.starDifferences %></h6></div>
                  <div class="col-xs-6"><h6 class="right">Def-Pt. Difference</h6></div>
                  <div class="col-xs-6"><h6 class="left"><%- dataTeamsParsed[clanAbbr].summary.ptDefDifference %></h6></div>
                  <div class="col-xs-6"><h6 class="right">Avg. Destruction</h6></div>
                  <div class="col-xs-6"><h6 class="left"><%- dataTeamsParsed[clanAbbr].summary.destruction %></h6></div>
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-10 col-md-offset-1">
                <h5 class="padded">Wars</h5>
                <%_ let idWars = `wars-${league}-${i+1}`; _%>
                <table id="<%- idWars %>" class="stripe nowrap"></table>
              </div>
            </div>
            <div class="row">
              <div class="col-md-8 col-md-offset-2">
                <h5 class="padded">Hitrate / Defrate</h5>
                <%_ let idHitrate = `rate-${league}-${i+1}`; _%>
                <table id="<%- idHitrate %>" class="stripe nowrap"></table>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-6 col-sm-offset-3">
                <h5 class="padded">T-Score</h5>
                <%_ let idChart = `myChart-${league}-${i+1}`; _%>
                <canvas id="<%- idChart %>"></canvas>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-4 col-sm-offset-2">
                <h5 class="padded">TH15</h5>
                <%_ let idChartTH15 = `myChart-${league}-${i+1}-th15`; _%>
                <canvas id="<%- idChartTH15 %>"></canvas>
              </div>
              <div class="col-sm-4">
                <h5 class="padded">TH14</h5>
                <%_ let idChartTH14 = `myChart-${league}-${i+1}-th14`; _%>
                <canvas id="<%- idChartTH14 %>"></canvas>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-4 col-sm-offset-2">
                <h5 class="padded">TH13</h5>
                <%_ let idChartTH13 = `myChart-${league}-${i+1}-th13`; _%>
                <canvas id="<%- idChartTH13 %>"></canvas>
              </div>
              <div class="col-sm-4">
                <h5 class="padded">TH12</h5>
                <%_ let idChartTH12 = `myChart-${league}-${i+1}-th12`; _%>
                <canvas id="<%- idChartTH12 %>"></canvas>
              </div>
            </div>
            <div class="row">
              <div class="col-md-10 col-md-offset-1">
                <h5 class="padded">Players</h5>
                <%_ let idClanPlayers = `players-${league}-${i+1}`; _%>
                <table id="<%- idClanPlayers %>" class="stripe nowrap"></table>
              </div>
            </div>
          </details>
          <% } %>
    		</div>
      </div>
      <div class="row text-center">
        <div class="col-md-12">
          <h4 class="padded">LEAGUE STATS</h4>
          <h6 class="padded">TH15</h6>
          <div class="row">
            <div class="col-md-10 col-md-offset-1">
              <table id="tableLeagueStats-mix-th15" class="stripe nowrap"></table>
              &nbsp;
            </div>
          </div>
          <canvas id="leagueStats-mix-th15"></canvas>
					<h6 class="padded">TH14</h6>
          <div class="row">
            <div class="col-md-10 col-md-offset-1">
              <table id="tableLeagueStats-mix-th14" class="stripe nowrap"></table>
              &nbsp;
            </div>
          </div>
          <canvas id="leagueStats-mix-th14"></canvas>
					<h6 class="padded">TH13</h6>
          <div class="row">
            <div class="col-md-10 col-md-offset-1">
              <table id="tableLeagueStats-mix-th13" class="stripe nowrap"></table>
              &nbsp;
            </div>
          </div>
          <canvas id="leagueStats-mix-th13"></canvas>
          <h6 class="padded">TH12</h6>
          <div class="row">
            <div class="col-md-10 col-md-offset-1">
              <table id="tableLeagueStats-mix-th12" class="stripe nowrap"></table>
              &nbsp;
            </div>
          </div>
          <canvas id="leagueStats-mix-th12"></canvas>
        </div>
      </div>
      <div class="row text-center">
        <div class="col-md-12">
          <h4 class="padded">PLAYERS</h4>
          <%_ let idPlayers = `players-${league}`; _%>
          <table id="<%- idPlayers %>" class="stripe nowrap"></table>
        </div>
      </div>
    </div>
	</section>
	<!-- footer -->
	<footer>
    <div class="text-center text-center-mobile">
      <h6 class = "link"><a href="https://discord.gg/rQz6KEY3E8">Discord</a></h6>
      <h6 class = "link"><a href="https://twitter.com/JWC_RANKING">Twitter</a></h6>
      <h6 class = "link"><a href="https://twitter.com/JwcMix">Twitter (Mix)</a></h6>
    </div>
	</footer>
	<!-- Holder for mobile navigation -->
	<div class="mobile-nav">
		<ul>
		</ul>
		<a href="#" class="close-link"><i class="arrow_up"></i></a>
	</div>
  
	<!-- Scripts -->
	<script src="js/jquery-1.11.1.min.js"></script>
	<script src="js/owl.carousel.min.js"></script>
	<script src="js/bootstrap.min.js"></script>
	<script src="js/typewriter.js"></script>
	<script src="js/jquery.onepagenav.js"></script>
	<script src="js/main.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.js"></script>
  <script>
    // tables
    let clanAbbrListParsed = JSON.parse('<%- clanAbbrList %>');
    let tableStandings = JSON.parse('<%- tableStandings %>');
    let tableWars = JSON.parse('<%- tableWars %>');
    let tableRate = JSON.parse('<%- tableRate %>');
    let tableClanPlayers = JSON.parse('<%- tableClanPlayers %>');
    let tablePlayers = JSON.parse('<%- tablePlayers %>');
    let tableLeagueStats = JSON.parse('<%- tableLeagueStats %>');
    jQuery(function($) {
      $("#standings-mix").DataTable(tableStandings);
      $("#players-mix").DataTable(tablePlayers);
      var league = "mix";
      clanAbbrListParsed[league].map((clanAbbr, index) => {
        let idWars = `#wars-${league}-${index+1}`;
        $(idWars).DataTable(tableWars[clanAbbr]);
        let idHitrate = `#rate-${league}-${index+1}`;
        $(idHitrate).DataTable(tableRate[clanAbbr]);
        let idClanPlayers = `#players-${league}-${index+1}`;
        $(idClanPlayers).DataTable(tableClanPlayers[clanAbbr]);
      });
      $("#tableLeagueStats-mix-th15").DataTable(tableLeagueStats.mix.th15);
      $("#tableLeagueStats-mix-th14").DataTable(tableLeagueStats.mix.th14);
      $("#tableLeagueStats-mix-th13").DataTable(tableLeagueStats.mix.th13);
      $("#tableLeagueStats-mix-th12").DataTable(tableLeagueStats.mix.th12);
    });
  </script>
  <script>
    // charts
    let chartData = JSON.parse('<%- chartData %>');
    let chartDataTH = JSON.parse('<%- chartDataTH %>');
    let chartOptions = {
      scales: {
        r: {
          angleLines: {
            display: false,
          },
          suggestedMin: 30,
          suggestedMax: 70,
        }
      },
      legend: {
        labels: {
          fontColor: 'black',
        }
      }
    };
    var league = "mix";
    clanAbbrListParsed[league].map((clanAbbr, index) => {
      var idChart = `myChart-${league}-${index+1}`;
      var ctx = document.getElementById(idChart);
      new Chart(ctx, {
        type: 'radar',
        data: chartData[clanAbbr],
        options: chartOptions,
      });
      var lvTH = "th15";
      var idChart2 = `myChart-${league}-${index+1}-${lvTH}`;
      var ctx = document.getElementById(idChart2);
      new Chart(ctx, {
        type: 'radar',
        data: chartDataTH[lvTH][clanAbbr],
        options: chartOptions,
      });
      var lvTH = "th14";
      var idChart2 = `myChart-${league}-${index+1}-${lvTH}`;
      var ctx = document.getElementById(idChart2);
      new Chart(ctx, {
        type: 'radar',
        data: chartDataTH[lvTH][clanAbbr],
        options: chartOptions,
      });
      var lvTH = "th13";
      var idChart2 = `myChart-${league}-${index+1}-${lvTH}`;
      var ctx = document.getElementById(idChart2);
      new Chart(ctx, {
        type: 'radar',
        data: chartDataTH[lvTH][clanAbbr],
        options: chartOptions,
      });
      var lvTH = "th12";
      var idChart2 = `myChart-${league}-${index+1}-${lvTH}`;
      var ctx = document.getElementById(idChart2);
      new Chart(ctx, {
        type: 'radar',
        data: chartDataTH[lvTH][clanAbbr],
        options: chartOptions,
      });
    });
  </script>
  <script>
    // charts league stats
    let chartDataLeagueStats = JSON.parse('<%- chartDataLeagueStats %>');
    let options = {
      scales: {
        y: {
          ticks: {
            stepSize: 10,
            callback: function(value, index, ticks){ return `${value}%` },
          },
          max: 100,
        }
      },
    };
    var league = "mix";
    var lvTH = "th15";
    var idChart = `leagueStats-${league}-${lvTH}`;
    var ctx = document.getElementById(idChart);
    new Chart(ctx, {
      type: 'bar',
      data: chartDataLeagueStats[league][lvTH],
      options: options,
    });
    var lvTH = "th14";
    var idChart = `leagueStats-${league}-${lvTH}`;
    var ctx = document.getElementById(idChart);
    new Chart(ctx, {
      type: 'bar',
      data: chartDataLeagueStats[league][lvTH],
      options: options,
    });
    var lvTH = "th13";
    var idChart = `leagueStats-${league}-${lvTH}`;
    var ctx = document.getElementById(idChart);
    new Chart(ctx, {
      type: 'bar',
      data: chartDataLeagueStats[league][lvTH],
      options: options,
    });
    var lvTH = "th12";
    var idChart = `leagueStats-${league}-${lvTH}`;
    var ctx = document.getElementById(idChart);
    new Chart(ctx, {
      type: 'bar',
      data: chartDataLeagueStats[league][lvTH],
      options: options,
    });
  </script>
</body>

</html>
